{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "installCommand": "bun install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/classify-reviews",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/generate-replies",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/post-replies",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/fetch-metrics",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/find-leads",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/scrape-emails",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-outreach",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-stats",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/zoe-find-leads",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/zoe-scrape-emails",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/zoe-send-outreach",
      "schedule": "*/5 * * * *"
    }
  ]
}
