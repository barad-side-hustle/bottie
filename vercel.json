{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn build",
  "installCommand": "yarn install --frozen-lockfile --ignore-engines",
  "crons": [
    {
      "path": "/api/cron/classify-reviews",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/generate-replies",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/post-replies",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/fetch-metrics",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/find-leads",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/find-leads",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/send-outreach",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/send-outreach",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/daily-stats",
      "schedule": "30 7 * * *"
    }
  ]
}
